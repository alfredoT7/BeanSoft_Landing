---
const links = [
  { href: '/', label: 'Inicio', icon: 'home' },
  { href: '/layout', label: 'Perfil', icon: 'user' },
  { href: '/vue-demo', label: 'Explorar', icon: 'send' },
];

const { currentPath = '/' } = Astro.props;
---

<footer class="fixed inset-x-0 bottom-6 z-30 flex justify-center px-4 print:hidden">
  <nav
    class="dock-shell flex items-center rounded-full"
    aria-label="Application dock"
    data-dock
  >
    <span class="dock-bg" aria-hidden="true" data-dock-bg></span>
  {
    links.map((link) => {
      const active = currentPath === link.href;

      return (
        <div class="dock-slot">
          <a
            href={link.href}
            aria-label={link.label}
            data-dock-item
            data-label={link.label}
            class:list={[
              'dock-item relative inline-flex size-10 items-center justify-center rounded-full border',
              active
                ? 'border-orange-200 bg-orange-50 text-orange-500 shadow-[inset_0_1px_0_rgba(255,255,255,0.7)] dark:border-orange-200 dark:bg-orange-50 dark:text-orange-500'
                : 'border-stone-200 bg-stone-50 text-stone-500 hover:text-stone-700 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-300 dark:hover:text-stone-100',
            ]}
          >
            {link.icon === 'home' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" class="size-5">
                <path d="M3 10a2 2 0 0 1 .7-1.5l7-6a2 2 0 0 1 2.6 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <path d="M9.5 13.8a4 4 0 0 1 5 0"></path>
                <path d="M12 17h.01"></path>
              </svg>
            )}
            {link.icon === 'user' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" class="size-5">
                <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            )}
            {link.icon === 'send' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" class="size-5">
                <path d="M22 2 11 13"></path>
                <path d="M22 2 15 22l-4-9-9-4z"></path>
              </svg>
            )}
          </a>
        </div>
      );
    })
  }
    <div class="dock-slot">
      <button
        type="button"
        aria-label="Cambiar tema"
        data-dock-item
        data-theme-toggle
        data-label="Tema"
        class="dock-item inline-flex size-10 items-center justify-center rounded-full border border-stone-200 bg-stone-50 text-stone-500 hover:text-stone-700 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-300 dark:hover:text-stone-100"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" class="size-5 dark:hidden">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" class="hidden size-5 dark:block">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9"></path>
        </svg>
      </button>
    </div>
  </nav>
</footer>

<style>
  .dock-shell {
    --dock-scale: 1;
    position: relative;
    gap: .55rem;
    height: 3.5rem;
    overflow: visible;
    padding: .5rem .9rem;
    isolation: isolate;
  }

  .dock-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    border: 1px solid rgba(231, 229, 228, .7);
    border-radius: 999px;
    background: linear-gradient(to bottom right, rgba(250, 250, 249, .9) 25%, rgba(245, 245, 244, .82));
    box-shadow: 0 18px 48px rgba(15, 23, 42, .18);
    transform: scaleX(1);
    transform-origin: center bottom;
    will-change: transform;
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
  }

  .dock-bg::after {
    content: "";
    position: absolute;
    inset: -.55rem -.8rem -.95rem;
    z-index: -1;
    border-radius: 999px;
    background:
      radial-gradient(ellipse at 50% 42%, rgba(255, 255, 255, .92), rgba(255, 255, 255, 0) 52%),
      radial-gradient(ellipse at 50% 68%, rgba(125, 211, 252, .34), rgba(125, 211, 252, 0) 74%);
    filter: blur(22px);
    opacity: 1;
    pointer-events: none;
  }

  :global(.dark) .dock-bg {
    border-color: rgba(63, 63, 70, .7);
    background: linear-gradient(to bottom right, rgba(28, 25, 23, .92) 25%, rgba(17, 24, 39, .86));
    box-shadow: 0 18px 48px rgba(0, 0, 0, .38);
  }

  :global(.dark) .dock-bg::after {
    background: radial-gradient(ellipse at center, rgba(56, 189, 248, .14), rgba(56, 189, 248, 0) 74%);
    filter: blur(18px);
    opacity: .85;
  }

  .dock-slot {
    --scale: 1;
    --lift: 0px;
    --push: 0px;
    --slot-extra: 0px;
    width: calc(2.9rem + var(--slot-extra));
    height: 2.5rem;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    flex: 0 0 auto;
    transform: translateX(var(--push));
    will-change: transform;
  }

  .dock-item {
    transform-origin: center bottom;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, .72),
      0 calc(8px * (var(--scale, 1) - .8)) calc(18px * (var(--scale, 1) - .7)) rgba(15, 23, 42, .12);
    transform: translateY(calc(var(--lift, 0) * -1)) scale(var(--scale, 1)) rotate(var(--tilt, 0deg));
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      box-shadow 160ms ease;
    will-change: transform;
  }

  .dock-item::before {
    content: attr(data-label);
    position: absolute;
    bottom: calc(100% + .75rem);
    left: 50%;
    max-width: 8rem;
    transform: translateX(-50%) translateY(.35rem) scale(.96);
    border-radius: 999px;
    background: rgba(15, 23, 42, .9);
    color: white;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1;
    opacity: 0;
    padding: .45rem .6rem;
    pointer-events: none;
    transition:
      opacity 120ms ease,
      transform 120ms ease;
    white-space: nowrap;
  }

  .dock-item:hover::before,
  .dock-item:focus-visible::before {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }

  .dock-item svg {
    transform: scale(calc(.92 + (var(--scale, 1) - 1) * .18));
    transition: transform 150ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .dock-item:active {
    transform: translateY(calc((var(--lift, 0) + 3px) * -1)) scale(calc(var(--scale, 1) * .94));
  }

  @media (prefers-reduced-motion: reduce) {
    .dock-shell,
    .dock-slot,
    .dock-item {
      transition: none;
    }
  }
</style>

<script>
  import { animate } from 'motion';

  const docks = Array.from(document.querySelectorAll('[data-dock]'));
  const storageKey = 'beansoft-theme';

  for (const dock of docks) {
    const dockBg = dock.querySelector('[data-dock-bg]');
    const toggle = dock.querySelector('[data-theme-toggle]');
    const slots = Array.from(dock.querySelectorAll('.dock-slot'));
    const radius = 146;
    const maxScale = 1.66;
    const maxLift = 12;
    const maxPush = 10;
    let pointerX = 0;
    let active = false;
    let frame = 0;
    let dockScale = 1;
    let dockScaleTarget = 1;
    let dockBgAnimation = null;
    let dockLeft = 0;
    let centers = [];
    const state = slots.map(() => ({
      scale: 1,
      lift: 0,
      push: 0,
      tilt: 0,
      targetScale: 1,
      targetLift: 0,
      targetPush: 0,
      targetTilt: 0,
      slotExtra: 0,
      targetSlotExtra: 0,
    }));

    const curve = (distance) => {
      if (distance >= radius) return 0;
      return (Math.cos((distance / radius) * Math.PI) + 1) / 2;
    };

    const measure = () => {
      const dockRect = dock.getBoundingClientRect();
      dockLeft = dockRect.left;
      centers = slots.map((slot) => slot.offsetLeft + slot.offsetWidth / 2);
    };

    const setTargets = () => {
      let peak = 1;
      const localPointerX = pointerX - dockLeft;

      slots.forEach((slot, index) => {
        const item = slot.querySelector('[data-dock-item]');
        const center = centers[index] ?? 0;
        const signedDistance = active ? localPointerX - center : radius;
        const influence = active ? curve(Math.abs(signedDistance)) : 0;
        const scale = 1 + influence * (maxScale - 1);
        const lift = influence * maxLift;
        const direction = Math.max(-1, Math.min(1, signedDistance / radius));
        const push = -direction * influence * maxPush;
        const tilt = Math.max(-1.4, Math.min(1.4, signedDistance / 70)) * influence;
        const slotExtra = influence * 13;
        const values = state[index];

        values.targetScale = scale;
        values.targetLift = lift;
        values.targetPush = push;
        values.targetTilt = tilt;
        values.targetSlotExtra = slotExtra;
        item?.style.setProperty('--scale-target', scale.toFixed(3));
        peak = Math.max(peak, scale);
      });

      return peak;
    };

    const render = () => {
      const peak = setTargets();
      const ease = active ? 0.22 : 0.16;

      slots.forEach((slot, index) => {
        const item = slot.querySelector('[data-dock-item]');
        const values = state[index];

        values.scale += (values.targetScale - values.scale) * ease;
        values.lift += (values.targetLift - values.lift) * ease;
        values.push += (values.targetPush - values.push) * ease;
        values.tilt += (values.targetTilt - values.tilt) * ease;
        values.slotExtra += (values.targetSlotExtra - values.slotExtra) * ease;

        item?.style.setProperty('--scale', values.scale.toFixed(3));
        item?.style.setProperty('--lift', `${values.lift.toFixed(2)}px`);
        item?.style.setProperty('--tilt', `${values.tilt.toFixed(2)}deg`);
        slot.style.setProperty('--push', `${values.push.toFixed(2)}px`);
        slot.style.setProperty('--slot-extra', `${values.slotExtra.toFixed(2)}px`);
      });

      dockScaleTarget = 1 + (peak - 1) * 0.34;

      if (dockBg && Math.abs(dockScaleTarget - dockScale) > 0.012) {
        dockScale = dockScaleTarget;
        dockBgAnimation?.stop();
        dockBgAnimation = animate(
          dockBg,
          { transform: `scaleX(${dockScaleTarget.toFixed(3)})` },
          { type: 'spring', stiffness: 360, damping: 34, mass: 0.42 }
        );
      }

      frame = requestAnimationFrame(render);
    };

    dock.addEventListener('pointermove', (event) => {
      pointerX = event.clientX;
      active = true;
    });
    dock.addEventListener('pointerenter', (event) => {
      measure();
      pointerX = event.clientX;
      active = true;
    });
    dock.addEventListener('pointerleave', () => {
      active = false;
    });
    dock.addEventListener('pointercancel', () => {
      active = false;
    });
    toggle?.addEventListener('click', () => {
      const root = document.documentElement;
      const nextTheme = root.classList.contains('dark') ? 'light' : 'dark';
      root.classList.toggle('dark', nextTheme === 'dark');
      root.dataset.theme = nextTheme;
      localStorage.setItem(storageKey, nextTheme);
    });
    measure();
    window.addEventListener('resize', measure);
    frame = requestAnimationFrame(render);

    document.addEventListener(
      'astro:before-swap',
      () => {
        cancelAnimationFrame(frame);
        dockBgAnimation?.stop();
        window.removeEventListener('resize', measure);
      },
      { once: true }
    );
  }
</script>
