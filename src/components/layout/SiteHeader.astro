---
import MainNav from '../navigation/MainNav.astro';

const { currentPath = '/', title = 'BeanSoft' } = Astro.props;
---

<header class="sticky top-0 z-20 border-b border-white/10 bg-stone-950/75 backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-4 lg:flex-row lg:items-center lg:justify-between">
    <div>
      <a href="/" class="text-lg font-black uppercase tracking-[0.28em] text-white">{title}</a>
      <p class="mt-1 text-sm text-stone-400">Astro shell. Vue islands. Tailwind surface.</p>
    </div>

    <MainNav currentPath={currentPath} />
  </div>
</header>
