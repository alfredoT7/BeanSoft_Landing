---
import StatusPanel from '../components/vue/StatusPanel.vue';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="BeanSoft" currentPath="/">
  <section class="flex min-h-[calc(100vh-10rem)] items-center">
    <div class="w-full rounded-[2rem] border border-stone-200/70 bg-white/70 p-8 shadow-2xl shadow-stone-300/30 backdrop-blur dark:border-white/10 dark:bg-white/5 dark:shadow-black/30">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-amber-600 dark:text-amber-200">BeanSoft</p>
      <h1 class="mt-4 max-w-4xl text-5xl font-black tracking-tight text-stone-950 dark:text-white sm:text-6xl">
        Astro base. Vue islands. Navbar shared.
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-8 text-stone-600 dark:text-stone-300">
        Home ahora usa layout común. Header y navegación viven fuera de páginas.
      </p>
      <div class="mt-8">
        <StatusPanel client:load />
      </div>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/layout"
          class="inline-flex rounded-full bg-amber-300 px-6 py-3 text-sm font-bold text-stone-950 transition hover:bg-amber-200"
        >
          Abrir demo layout
        </a>
        <a
          href="/vue-demo"
          class="inline-flex rounded-full border border-cyan-400/40 px-6 py-3 text-sm font-bold text-cyan-700 transition hover:border-cyan-500 hover:text-cyan-900 dark:border-cyan-300/30 dark:text-cyan-100 dark:hover:border-cyan-200 dark:hover:text-white"
        >
          Abrir demo Vue
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
